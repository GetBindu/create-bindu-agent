# ----------------------------------------------------------------------------
# Open Router Configuration
# ----------------------------------------------------------------------------
# Used for LLM API calls
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Type: "postgres" for PostgreSQL or "memory" for in-memory storage
#STORAGE_TYPE=postgres
#DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_C8a1bjrDQIMG@ep-spring-silence-agv3jy3d-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------------------------
# Scheduler Configuration
# ----------------------------------------------------------------------------
# Type: "redis" for distributed scheduling or "memory" for single-process
#SCHEDULER_TYPE=redis
#REDIS_URL=redis://default:41rk6qp3w7z3OsB0OSYmHkubrJcM2qDt@redis.getbindu.com:6379

# ----------------------------------------------------------------------------
# Sentry Configuration
# ----------------------------------------------------------------------------
# Enable error tracking and performance monitoring
SENTRY_ENABLED=true
SENTRY_DSN=https://<your-sentry-dsn>@<your-sentry-org>.ingest.de.sentry.io/<your-sentry-project-id>

# ----------------------------------------------------------------------------
# Open Telemetry Configuration
# ----------------------------------------------------------------------------
{% if cookiecutter.observability_provider != "none" %}# Enable observability and tracing
TELEMETRY_ENABLED=true
OLTP_VERBOSE_LOGGING=true
OLTP_SERVICE_NAME={{ cookiecutter.project_slug }}
{% if cookiecutter.observability_provider == "langfuse" %}# Langfuse Configuration
OLTP_ENDPOINT="https://cloud.langfuse.com/api/public/otel/v1/traces"
OLTP_HEADERS={"Authorization":"Basic <base64-encoded-public-key:secret-key>"}
# echo -n "pk-lf-1234567890:sk-lf-1234567890" | base64
{% elif cookiecutter.observability_provider == "phoenix" %}# Phoenix Configuration
OLTP_ENDPOINT="http://localhost:6006/v1/traces"
{% elif cookiecutter.observability_provider == "jaeger" %}# Jaeger Configuration
OLTP_ENDPOINT="http://localhost:4318/v1/traces"
{% endif %}{% else %}# Telemetry disabled
#TELEMETRY_ENABLED=false
{% endif %}

# ----------------------------------------------------------------------------
# Hydra Configuration
# ----------------------------------------------------------------------------
# Enable authentication (if auth_provider is enabled)
{% if cookiecutter.auth_provider == "y" %}AUTH__ENABLED=true{% else %}#AUTH__ENABLED=false{% endif %}

# Set provider to Hydra
AUTH__PROVIDER=hydra

HYDRA__ADMIN_URL=https://hydra-admin.getbindu.com
HYDRA__PUBLIC_URL=https://hydra.getbindu.com

# ----------------------------------------------------------------------------
# Vault Configuration
# ----------------------------------------------------------------------------
# Enable Vault integration for persistent credential storage
VAULT__ENABLED=false

# Vault server URL
VAULT__URL=https://vault.getbindu.com

# Vault authentication token
VAULT__TOKEN=your_vault_token_here
