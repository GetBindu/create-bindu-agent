{
  "author": "{{ cookiecutter.email }}",
  "name": "{{ cookiecutter.project_name }}",
  "description": "{{ cookiecutter.project_description }}",
  "version": "{{ cookiecutter._agent_version }}",
  "skills": [],
  "capabilities": {},
  {% if cookiecutter.enable_paywall == "y" %}"execution_cost": {
    "amount": "{{ cookiecutter._paywall_amount }}",
    "token": "{{ cookiecutter._paywall_token }}",
    "network": "{{ cookiecutter._paywall_network }}",
    "pay_to_address": "{{ cookiecutter._paywall_address }}",
    "protected_methods": [
      "message/send"
    ]
  },
  {% endif %}"agent_trust": "low",
  "kind": "agent",
  "extra_metadata": {
    "domain": "general",
    "specialization": "{{ cookiecutter.project_slug }}"
  },
  "deployment": {
    "url": "http://localhost:{{ cookiecutter._deployment_port }}",
    "expose": true,
    "cors_origins": ["*"]
  }
}
