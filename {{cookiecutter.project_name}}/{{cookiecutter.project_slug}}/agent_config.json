{
  "author": "{{ cookiecutter.email }}",
  "name": "{{ cookiecutter.project_name }}",
  "description": "{{ cookiecutter.project_description }}",
  "version": "{{ cookiecutter._agent_version }}",
  "recreate_keys": false,
  "skills": [{% if cookiecutter.skill_names %}
    {% set skill_list = cookiecutter.skill_names.split(',') %}
    {% for skill in skill_list %}
    {% set skill_trimmed = skill.strip() %}
    {% if skill_trimmed and not skill_trimmed.startswith('💼') and not skill_trimmed.startswith('Enter') %}
    "skills/{{ skill_trimmed }}"{% if not loop.last %},{% endif %}
    {% endif %}
    {% endfor %}
{% endif %}
  ],
  "capabilities": {},
  {% if cookiecutter.enable_paywall == "y" %}"execution_cost": {
    "amount": "{{ cookiecutter._paywall_amount }}",
    "token": "{{ cookiecutter._paywall_token }}",
    "network": "{{ cookiecutter._paywall_network }}",
    "pay_to_address": "{{ cookiecutter._paywall_address }}",
    "protected_methods": [
      "message/send"
    ]
  },
  {% endif %}"agent_trust": "low",
  "kind": "agent",
  "debug_mode": true,
  "debug_level": 2,
  "monitoring": false,
  "telemetry": {% if cookiecutter.observability_provider != "none" %}true{% else %}false{% endif %},
  "num_history_sessions": 5,
  "enable_system_message": true,
  "enable_context_based_history": false,
  "documentation_url": "https://docs.getbindu.com/agents/{{ cookiecutter.project_slug }}",
  "extra_metadata": {
    "domain": "general",
    "specialization": "{{ cookiecutter.project_slug }}"
  },
  {% if cookiecutter.auth_provider == "y" %}"auth": {
    "enabled": true
  },
  {% else %}"auth": {
    "enabled": false
  },
  {% endif %}"deployment": {
    "url": "http://localhost:{{ cookiecutter._deployment_port }}",
    "expose": true,
    "protocol_version": "1.0.0",
    "proxy_urls": ["https://{{ cookiecutter.project_slug }}.getbindu.com"],
    "cors_origins": ["*"]
  },
  "storage": {
    "type": "{{ cookiecutter.storage_type }}"
  },
  "scheduler": {
    "type": "{{ cookiecutter.scheduler_type }}"
  }{% if cookiecutter.observability_provider != "none" %},
  "oltp_endpoint": [
    {% if cookiecutter.observability_provider == "jaeger" %}"http://localhost:4318/v1/traces"{% elif cookiecutter.observability_provider == "phoenix" %}"http://localhost:6006/v1/traces"{% elif cookiecutter.observability_provider == "langfuse" %}"https://cloud.langfuse.com/api/public/otel/v1/traces"{% endif %}
  ],
  "oltp_service_name": "{{ cookiecutter.project_slug }}",
  "oltp_verbose_logging": true,
  "oltp_service_version": "{{ cookiecutter._agent_version }}",
  "oltp_deployment_environment": "production",
  "oltp_batch_max_queue_size": 2048,
  "oltp_batch_schedule_delay_millis": 5000,
  "oltp_batch_max_export_batch_size": 512,
  "oltp_batch_export_timeout_millis": 30000{% endif %}
}
