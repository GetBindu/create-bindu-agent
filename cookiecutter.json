{
  "author": "Bindu Sunflower",
  "email": "bindu.builder@getbindu.com",
  "author_github_handle": "bindu-wizard",
  "dockerhub_username": "{{cookiecutter.author_github_handle}}",
  "project_name": "my-bindu-agent",
  "project_slug": "{{cookiecutter.project_name|lower|replace('-', '_')}}",
  "project_description": "A Bindu AI agent for intelligent task handling",
  "agent_framework": [
    "agno",
    "langchain",
    "crew",
    "fastagent",
    "openai agent",
    "google adk agent",
    "custom"
  ],
  "skill_names": "💼 Business: 1-finance 2-financial-coach 3-competitor-analysis 4-startup-analyst 5-explainable-business | 🔬 Research: 6-deep-research 7-analyze-paper 8-hackernews 9-media-trend | 🎨 Creative: 10-instagram 11-meme 12-screenplay 13-recipe 14-youtube 15-web-extraction | 🌟 Lifestyle: 16-travel 17-surprise-travel 18-shopping 19-movie 20-book | 💚 Health: 21-breakup 22-23-24-25-cbt | ⚙️ Tech: 26-architect 27-biomni | ⚖️ Legal: 28-29-legal-zk | Enter numbers (e.g. 1,6,10) or skill names, or press Enter to skip",
  "auth_provider": [
    "none",
    "auth0",
    "cognito",
    "azure-ad",
    "google"
  ],
  "observability_provider": [
    "none",
    "phoenix",
    "jaeger",
    "langfuse"
  ],
  "security_features": [
    "none",
    "did-and-pki",
    "did-only",
    "pki-only"
  ],
  "include_github_actions": [
    "y",
    "n"
  ],
  "open_source_license": [
    "Apache Software License 2.0",
    "MIT license",
    "BSD license",
    "ISC license",
    "GNU General Public License v3",
    "Not open source"
  ],
  "_comment": "Internal defaults (not prompted to user)",
  "_agent_version": "1.0.0",
  "_bindu_version": "2026.9.4",
  "_deployment_host": "0.0.0.0",
  "_deployment_port": "3773",
  "_log_level": "info",
  "_storage_type": "memory",
  "_scheduler_type": "memory",
  "_type_checker": "ty",
  "_enable_system_message": "y",
  "_enable_context_based_history": "n",
  "_include_dockerfile": "y",
  "_verification_key_type": "rsa",
  "_recreate_keys": "n",
  "_enable_execution_cost": "n",
  "_telemetry_backend": "jaeger",
  "_oltp_endpoint": "http://localhost:4318/v1/traces",
  "_phoenix_endpoint": "http://localhost:6006",
  "_langfuse_endpoint": "http://localhost:3000"
}
